# Stop the i915 driver from loading for iGPU passthrough
blacklist i915
install i915 /bin/false
blacklist xe

# disable vga (8086:7d51) device
options vfio-pci ids=8086:7d51 disable_vga=1
# disable vga (8086:7d51) and audio (8086:7728) devices
#options vfio-pci ids=8086:7d51,8086:7728 disable_vga=1

# Only blacklist related audio drivers if you need to pass through HDMI/DisplayPort audio
#blacklist snd_hda_intel
#blacklist snd_hda_codec_hdmi
