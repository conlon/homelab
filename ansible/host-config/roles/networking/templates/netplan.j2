network:
  version: 2
  ethernets:
    {{ interface | default('ens18') }}:
      dhcp4: false
      addresses:
        - {{ permanent_host_ip }}/24
      nameservers:
        addresses:
{% for nameserver in nameservers %}
          - {{ nameserver }}
{% endfor %}
        search: []
      routes:
        - to: default
          via: {{ routers | first }}
