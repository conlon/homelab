{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekdays",
    ":preserveSemverRanges",
    ":combinePatchMinorReleases",
    ":separateMajorReleases",
    ":separateMultipleMajorReleases",
    ":rebaseStalePrs",
    "docker:enableMajor"
  ],
  "pip-compile": {
    "fileMatch": ["(^|/)requirements\\.in$"]
  },
  "ignorePaths": ["**/requirements.txt"],
  "kubernetes": {
    "fileMatch": ["\\.yaml$"]
  },
  "dependencyDashboard": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Limit linuxserver packages to not use dated versions",
      "matchPackagePatterns": [".*linuxserver.*"],
      "allowedVersions": "<2000"
    },
    {
      "description": "Limit qbittorent packages below 14.x which strangely exists in the same registry",
      "matchPackagePatterns": [".*linuxserver.*"],
      "allowedVersions": "<14"
    },
    {
      "description": "Ansible role/galaxy updates require manual dashboard approval, but automerge for patch/minor updates",
      "matchManagers": ["ansible", "ansible-galaxy"],
      "dependencyDashboardApproval": true,
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["ansible"],
      "groupName": "ansible dependencies"
    },
    {
      "description": "Docker/container image updates auto-create PRs",
      "matchManagers": ["dockerfile", "docker-compose", "kubernetes"],
      "labels": ["docker"]
    },
    {
      "matchPackageNames": ["louislam/uptime-kuma"],
      "sourceUrl": "https://github.com/louislam/uptime-kuma"
    },
    {
      "matchPackageNames": ["pihole/pihole"],
      "sourceUrl": "https://github.com/pi-hole/docker-pi-hole"
    },
    {
      "matchPackageNames": ["lscr.io/linuxserver/bazarr"],
      "sourceUrl": "https://github.com/morpheus65535/bazarr"
    },
    {
      "matchPackageNames": ["lscr.io/linuxserver/sonarr"],
      "sourceUrl": "https://github.com/Sonarr/Sonarr"
    },
    {
      "matchPackageNames": ["lscr.io/linuxserver/prowlarr"],
      "sourceUrl": "https://github.com/Prowlarr/Prowlarr"
    },
    {
      "matchPackageNames": ["lscr.io/linuxserver/radarr"],
      "sourceUrl": "https://github.com/Radarr/Radarr"
    },
    {
      "matchPackageNames": ["lscr.io/linuxserver/overseerr"],
      "sourceUrl": "https://github.com/sctx/overseerr"
    }
  ]
}
